# ===== Python 后端 =====
# 虚拟环境（你用的是 .venv，在 backend 同级目录，也要忽略）
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/

# Python 缓存
__pycache__/
*.py[cod]
*$py.class
*.so
.pytest_cache/
.coverage
htmlcov/

# 环境变量（包含 API Key，绝对不能上传）
.env
.env.local
.env.*.local

# IDE 配置
.vscode/
.idea/
*.swp
*.swo

# ===== 前端（my-rag-frontend）=====
my-rag-frontend/node_modules/
my-rag-frontend/dist/
my-rag-frontend/.vite/
my-rag-frontend/.env.local
my-rag-frontend/.env.production

# 构建产物
my-rag-frontend/*.log
my-rag-frontend/*.tsbuildinfo

# ===== 系统文件 =====
.DS_Store
Thumbs.db
desktop.ini
.data/chroma
.data/chat_history.db
